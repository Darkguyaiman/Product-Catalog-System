<h1>Settings</h1>

<% 
const categoryById = {};
(categories || []).forEach(function (c) { categoryById[c.id] = c; });

function normParentId(pid) {
    if (pid === null || pid === undefined || pid === '') return null;
    return pid;
}

function sortedChildrenOf(parentId) {
    return (categories || []).filter(function (c) {
        if (parentId === null) return normParentId(c.parent_id) === null;
        return parentId == c.parent_id;
    }).sort(function (a, b) { return a.name.localeCompare(b.name); });
}

var treeRows = [];
function walkSubtree(cat, depth) {
    treeRows.push({ cat: cat, depth: depth });
    sortedChildrenOf(cat.id).forEach(function (ch) { walkSubtree(ch, depth + 1); });
}
sortedChildrenOf(null).forEach(function (root) { walkSubtree(root, 0); });

var inTree = {};
treeRows.forEach(function (r) { inTree[r.cat.id] = true; });
var orphans = (categories || []).filter(function (c) { return !inTree[c.id]; });

var parentSelectOptions = [];
function walkParentOptions(parentId, depth) {
    sortedChildrenOf(parentId).forEach(function (c) {
        var prefix = depth > 0 ? new Array(depth + 1).join('— ') : '';
        parentSelectOptions.push({ id: c.id, label: prefix + c.name });
        walkParentOptions(c.id, depth + 1);
    });
}
walkParentOptions(null, 0);
%>

<div class="tabs">
    <a href="/admin/settings" class="tab" style="text-decoration: none; color: inherit;">General Settings</a>
    <div class="tab active">Categories</div>
    <% if (user.role==='Admin' || user.role==='Super Admin' ) { %>
        <a href="/admin/settings/users" class="tab" style="text-decoration: none; color: inherit;">Users</a>
        <% } %>
</div>

<div class="card">
    <h3>Categories</h3>
    <form action="/admin/settings/categories/add" method="POST" class="form-group responsive-flex items-end">
        <div class="flex-1">
            <label>Category Name</label>
            <input type="text" name="name" required>
        </div>
        <div class="flex-1">
            <label>Main Category (Optional)</label>
            <select name="parent_id">
                <option value="">-- None (Main Category) --</option>
                <% parentSelectOptions.forEach(function(opt) { %>
                    <option value="<%= opt.id %>"><%= opt.label %></option>
                    <% }); %>
            </select>
        </div>
        <button type="submit" class="btn btn-primary">Add Category</button>
    </form>

    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>Relationship</th>
                    <th>Category Name</th>
                    <th style="width: 120px;">Action</th>
                </tr>
            </thead>
            <tbody>
                <% treeRows.forEach(function(row) {
                    var cat = row.cat;
                    var depth = row.depth;
                    var parentCat = cat.parent_id ? categoryById[cat.parent_id] : null;
                    %>
                        <tr style="<%= depth === 0 ? 'background-color: var(--gray-50);' : '' %>">
                            <td>
                                <% if (depth === 0) { %>
                                    <span class="badge badge-primary">Main</span>
                                <% } else { %>
                                    <span class="badge" style="background-color: var(--gray-100); color: var(--gray-600);">Sub of <%= parentCat ? parentCat.name : '?' %></span>
                                <% } %>
                            </td>
                            <td style="font-weight: <%= depth === 0 ? '700' : '400' %>; color: <%= depth === 0 ? 'var(--blue-darkest)' : 'inherit' %>; padding-left: <%= depth === 0 ? 'inherit' : (2.5 + (depth - 1) * 1.25) %>rem;">
                                <% if (depth === 0) { %>
                                    <i class="fas fa-folder" style="margin-right: 8px; color: var(--blue-medium);"></i>
                                <% } else { %>
                                    <i class="fas fa-level-up-alt fa-rotate-90" style="margin-right: 8px; color: var(--gray-400);"></i>
                                <% } %>
                                <%= cat.name %>
                            </td>
                            <td>
                                <div style="display: flex; gap: 5px;">
                                    <button onclick="openEditModal('<%= cat.id %>', '<%= cat.name %>', '<%= cat.parent_id || '' %>')"
                                        class="btn btn-secondary" style="padding: 4px 8px; font-size: 12px;">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <% if (user.role==='Super Admin' ) { %>
                                        <button
                                            onclick="openDeleteModal('/admin/settings/categories/delete/<%= cat.id %>', 'Are you sure you want to delete the category \'<%= cat.name %>\'?<%= depth === 0 ? ' All nested sub-categories will be disconnected.' : '' %>')"
                                            class="btn btn-danger" style="padding: 4px 8px; font-size: 12px;">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                        <% } %>
                                </div>
                            </td>
                        </tr>
                    <% }); %>

                                    <% if (orphans.length > 0) {
                                        orphans.forEach(function(orphan) { %>
                                        <tr>
                                            <td><span class="badge badge-danger">Broken Main Ref</span></td>
                                            <td style="padding-left: 2.5rem; color: var(--danger);">
                                                <i class="fas fa-exclamation-triangle" style="margin-right: 8px;"></i>
                                                <%= orphan.name %> (Orphan)
                                            </td>
                                            <td>
                                                <div style="display: flex; gap: 5px;">
                                                    <button
                                                        onclick="openEditModal('<%= orphan.id %>', '<%= orphan.name %>', '')"
                                                        class="btn btn-secondary"
                                                        style="padding: 4px 8px; font-size: 12px;">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                    <% if (user.role==='Super Admin' ) { %>
                                                        <button
                                                            onclick="openDeleteModal('/admin/settings/categories/delete/<%= orphan.id %>', 'Are you sure you want to delete the orphan category \'<%= orphan.name %>\'?')"
                                                            class="btn btn-danger"
                                                            style="padding: 4px 8px; font-size: 12px;">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                        <% } %>
                                                </div>
                                            </td>
                                        </tr>
                                        <% }); } %>
            </tbody>
        </table>
    </div>

    <!-- Mobile Card View -->
    <div class="mobile-category-cards">
        <% treeRows.forEach(function(row) {
            var cat = row.cat;
            var depth = row.depth;
            var parentCat = cat.parent_id ? categoryById[cat.parent_id] : null;
            var ml = depth * 1.5;
            %>
            <div class="category-card" style="<%= depth > 0 ? 'margin-left: ' + ml + 'rem; border-left: 3px solid var(--gray-200);' : '' %>">
                <div class="category-card-header">
                    <div class="category-card-name">
                        <% if (depth === 0) { %>
                            <i class="fas fa-folder" style="color: var(--blue-medium);"></i>
                        <% } else { %>
                            <i class="fas fa-level-up-alt fa-rotate-90" style="color: var(--gray-400);"></i>
                        <% } %>
                        <%= cat.name %>
                    </div>
                    <div class="category-card-actions">
                        <button onclick="openEditModal('<%= cat.id %>', '<%= cat.name %>', '<%= cat.parent_id || '' %>')"
                            class="btn btn-secondary btn-sm">
                            <i class="fas fa-edit"></i>
                        </button>
                        <% if (user.role==='Super Admin' ) { %>
                            <button
                                onclick="openDeleteModal('/admin/settings/categories/delete/<%= cat.id %>', 'Delete category \'<%= cat.name %>\'?<%= depth === 0 ? ' All nested sub-categories will be disconnected.' : '' %>')"
                                class="btn btn-danger btn-sm">
                                <i class="fas fa-trash"></i>
                            </button>
                            <% } %>
                    </div>
                </div>
                <div class="category-card-details">
                    <% if (depth === 0) { %>
                        <span class="category-card-badge">Main Category</span>
                    <% } else { %>
                        <span class="category-card-badge">Sub of <%= parentCat ? parentCat.name : '?' %></span>
                    <% } %>
                </div>
            </div>
        <% }); %>

                        <% if (orphans.length> 0) { %>
                            <div
                                style="margin-top: 2rem; padding-bottom: 0.5rem; border-bottom: 2px solid var(--danger); color: var(--danger); font-weight: 700;">
                                <i class="fas fa-exclamation-triangle"></i> Orphan Categories
                            </div>
                            <% orphans.forEach(function(orphan) { %>
                                <div class="category-card" style="border-left: 3px solid var(--danger);">
                                    <div class="category-card-header">
                                        <div class="category-card-name" style="color: var(--danger);">
                                            <%= orphan.name %>
                                        </div>
                                        <div class="category-card-actions">
                                            <button
                                                onclick="openEditModal('<%= orphan.id %>', '<%= orphan.name %>', '')"
                                                class="btn btn-secondary btn-sm">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <% if (user.role==='Super Admin' ) { %>
                                                <button
                                                    onclick="openDeleteModal('/admin/settings/categories/delete/<%= orphan.id %>', 'Delete orphan category \'<%= orphan.name %>\'?')"
                                                    class="btn btn-danger btn-sm">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                                <% } %>
                                        </div>
                                    </div>
                                    <div class="category-card-details">
                                        <span class="badge badge-danger">Broken Main Relationship</span>
                                    </div>
                                </div>
                                <% }); %>
                                    <% } %>
    </div>
</div>


<!-- Custom Modals -->
<div id="modalOverlay" class="modal-overlay" style="display: none;">
    <!-- Edit Category Modal -->
    <div id="editCategoryModal" class="custom-modal-content" style="display: none;">
        <div class="modal-header">
            <h3>Edit Category</h3>
            <button onclick="closeAllModals()" class="close-btn">&times;</button>
        </div>
        <form id="editCategoryForm" method="POST" style="margin-top: 1rem;">
            <div class="form-group">
                <label>Category Name</label>
                <input type="text" name="name" id="edit_name" required>
            </div>
            <div class="form-group" style="margin-top: 1rem;">
                <label>Main Category</label>
                <select name="parent_id" id="edit_parent_id">
                    <option value="">-- None (Main Category) --</option>
                    <% parentSelectOptions.forEach(function(opt) { %>
                        <option value="<%= opt.id %>"><%= opt.label %></option>
                        <% }); %>
                </select>
            </div>
            <div style="display: flex; gap: 10px; margin-top: 2rem;">
                <button type="button" onclick="closeAllModals()" class="btn btn-secondary"
                    style="flex: 1;">Cancel</button>
                <button type="submit" class="btn btn-primary" style="flex: 1;">Save Changes</button>
            </div>
        </form>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="deleteConfirmationModal" class="custom-modal-content"
        style="display: none; border-top: 4px solid var(--danger);">
        <div style="text-align: center; padding: 1rem 0;">
            <div
                style="width: 60px; height: 60px; background: #fee2e2; color: var(--danger); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; font-size: 1.5rem;">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h3 style="margin-bottom: 0.5rem;">Are you sure?</h3>
            <p id="deleteModalMessage" style="color: var(--gray-600); font-size: 0.95rem;">This action cannot be undone.
            </p>
        </div>
        <div style="display: flex; gap: 10px; margin-top: 1.5rem;">
            <button type="button" onclick="closeAllModals()" class="btn btn-secondary" style="flex: 1;">Cancel</button>
            <form id="deleteConfirmForm" method="POST" style="flex: 1;">
                <button type="submit" class="btn btn-danger" style="width: 100%;">Yes, Delete</button>
            </form>
        </div>
    </div>
</div>

<style>
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px);
        z-index: 2000;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .custom-modal-content {
        background: var(--white);
        padding: 2rem;
        border-radius: 12px;
        width: 100%;
        max-width: 400px;
        box-shadow: var(--shadow-lg);
        animation: modalScaleUp 0.2s ease-out;
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid var(--gray-100);
        padding-bottom: 1rem;
    }

    .modal-header h3 {
        margin: 0;
        font-size: 1.25rem;
    }

    .close-btn {
        background: none;
        border: none;
        font-size: 1.5rem;
        color: var(--gray-400);
        cursor: pointer;
        line-height: 1;
    }

    @keyframes modalScaleUp {
        from {
            opacity: 0;
            transform: scale(0.95) translateY(10px);
        }

        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }
</style>

<script id="category-parent-json" type="application/json"><%- JSON.stringify((categories || []).map(function (c) {
    return { id: c.id, parent_id: c.parent_id == null || c.parent_id === '' ? null : c.parent_id };
})) %></script>

<script>
    function getDescendantIds(editId) {
        var el = document.getElementById('category-parent-json');
        if (!el) return new Set();
        var data = JSON.parse(el.textContent);
        var byParent = {};
        data.forEach(function (c) {
            var pk = c.parent_id == null ? '__root__' : String(c.parent_id);
            if (!byParent[pk]) byParent[pk] = [];
            byParent[pk].push(c.id);
        });
        var out = new Set();
        var stack = [String(editId)];
        while (stack.length) {
            var id = stack.pop();
            (byParent[id] || []).forEach(function (k) {
                var sk = String(k);
                if (!out.has(sk)) {
                    out.add(sk);
                    stack.push(sk);
                }
            });
        }
        return out;
    }

    function openEditModal(id, name, parentId) {
        const overlay = document.getElementById('modalOverlay');
        const modal = document.getElementById('editCategoryModal');
        const form = document.getElementById('editCategoryForm');
        const nameInput = document.getElementById('edit_name');
        const parentSelect = document.getElementById('edit_parent_id');
        const sid = String(id);

        form.action = '/admin/settings/categories/edit/' + id;
        nameInput.value = name;
        parentSelect.value = parentId !== undefined && parentId !== null && parentId !== '' ? String(parentId) : '';

        var descendants = getDescendantIds(id);
        Array.from(parentSelect.options).forEach(function (opt) {
            if (!opt.value) {
                opt.disabled = false;
                return;
            }
            var ov = String(opt.value);
            opt.disabled = ov === sid || descendants.has(ov);
        });

        overlay.style.display = 'flex';
        modal.style.display = 'block';
        document.getElementById('deleteConfirmationModal').style.display = 'none';

        // Scroll to top of modal for visibility
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function openDeleteModal(actionUrl, message) {
        const overlay = document.getElementById('modalOverlay');
        const modal = document.getElementById('deleteConfirmationModal');
        const form = document.getElementById('deleteConfirmForm');
        const messageEl = document.getElementById('deleteModalMessage');

        form.action = actionUrl;
        messageEl.textContent = message;

        overlay.style.display = 'flex';
        modal.style.display = 'block';
        document.getElementById('editCategoryModal').style.display = 'none';

        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function closeAllModals() {
        document.getElementById('modalOverlay').style.display = 'none';
    }

    document.getElementById('modalOverlay').addEventListener('click', function (e) {
        if (e.target === this) closeAllModals();
    });
</script>