<%
    const activeRange = dateRange || {};
    const activeStartDate = activeRange.startDate || '';
    const activeEndDate = activeRange.endDate || '';
    const activePreset = activeRange.preset || 'this_month';
    const reportDownloadUrl = '/admin/download-pdf?preset=' + encodeURIComponent(activePreset)
        + (activeStartDate ? '&startDate=' + encodeURIComponent(activeStartDate) : '')
        + (activeEndDate ? '&endDate=' + encodeURIComponent(activeEndDate) : '');
%>
<div class="dashboard-page">
    <div class="dashboard-topbar">
        <div>
            <h1>Dashboard Overview</h1>
            <p>Welcome back! Here's a real-time snapshot of your catalog.</p>
        </div>
        <div class="dashboard-actions">
            <a href="<%= reportDownloadUrl %>" class="dashboard-pdf-button">
                <i class="fa-solid fa-file-pdf"></i>
                <span>Download PDF</span>
            </a>
            <button type="button" class="date-range-button" id="openDateRangePanel">
                <i class="fa-solid fa-calendar-days"></i>
                <span id="dateRangeButtonLabel">This month</span>
                <i class="fa-solid fa-chevron-down"></i>
            </button>
        </div>
    </div>

    <!-- Stats Section -->
    <div class="stats-container">
        <!-- Main Stats Row -->
        <div class="stats-row main-stats">
            <div class="stat-card glass products">
                <div class="stat-icon">
                    <i class="fa-solid fa-box-open"></i>
                </div>
                <div class="stat-content">
                    <p class="stat-label">Total Products</p>
                    <h2 class="stat-value">
                        <%= totalProducts %>
                    </h2>
                </div>
                <div class="stat-footer">
                    <i class="fas fa-box" aria-hidden="true"></i>
                    The Number of Products in the System
                </div>
            </div>

            <div class="stat-card glass companies">
                <div class="stat-icon">
                    <i class="fa-solid fa-building"></i>
                </div>
                <div class="stat-content">
                    <p class="stat-label">Total Companies</p>
                    <h2 class="stat-value">
                        <%= totalCompanies %>
                    </h2>
                </div>
                <div class="stat-footer">
                    <i class="fa-solid fa-network-wired"></i> Total Number of Affiliated Companies in the System
                </div>
            </div>

            <div class="stat-card glass suppliers">
                <div class="stat-icon">
                    <i class="fa-solid fa-truck-field"></i>
                </div>
                <div class="stat-content">
                    <p class="stat-label">Total Suppliers</p>
                    <h2 class="stat-value">
                        <%= totalSuppliers %>
                    </h2>
                </div>
                <div class="stat-footer">
                    <i class="fa-solid fa-globe"></i> Total Number of Suppliers in the System
                </div>
            </div>

            <div class="stat-card glass completeness">
                <div class="stat-icon">
                    <i class="fa-solid fa-list-check"></i>
                </div>
                <div class="stat-content">
                    <p class="stat-label">Catalog Completeness</p>
                    <h2 class="stat-value">
                        <%= catalogCompleteness %>%
                    </h2>
                </div>
                <div class="completeness-track" aria-label="Catalog completeness">
                    <div class="completeness-fill" style="width: <%= Math.max(0, Math.min(100, catalogCompleteness || 0)) %>%;"></div>
                </div>
                <div class="stat-footer">
                    <i class="fa-solid fa-circle-check"></i>
                    Average product detail completion
                </div>
            </div>
        </div>

        <!-- Product Health Row -->
        <div class="stats-row product-health-stats">
            <div class="stat-card detail active-products">
                <div class="detail-header">
                    <span class="detail-icon"><i class="fa-solid fa-toggle-on"></i></span>
                </div>
                <p class="detail-label">Active Products</p>
                <h2 class="detail-value">
                    <%= activeProducts %>
                </h2>
                <p class="detail-hint">Visible in public catalog pages</p>
            </div>

            <div class="stat-card detail inactive-products">
                <div class="detail-header">
                    <span class="detail-icon"><i class="fa-solid fa-toggle-off"></i></span>
                </div>
                <p class="detail-label">Inactive Products</p>
                <h2 class="detail-value">
                    <%= inactiveProducts %>
                </h2>
                <p class="detail-hint">Hidden from public catalog pages</p>
            </div>

            <div class="stat-card detail missing-images">
                <div class="detail-header">
                    <span class="detail-icon"><i class="fa-solid fa-image"></i></span>
                </div>
                <p class="detail-label">Missing Images</p>
                <h2 class="detail-value">
                    <%= missingProductImages %>
                </h2>
                <p class="detail-hint">Products without any image</p>
            </div>
        </div>

        <!-- Marketing Trends Row -->
        <div class="stats-row trend-stats">
            <div class="stat-card detail testimonials">
                <div class="detail-header">
                    <span class="detail-icon"><i class="fa-solid fa-comment-dots"></i></span>
                    <span class="trend-badge <%= testimonialsChange >= 0 ? 'up' : 'down' %>">
                        <i
                            class="fa-solid <%= testimonialsChange >= 0 ? 'fa-arrow-trend-up' : 'fa-arrow-trend-down' %>"></i>
                        <%= Math.abs(testimonialsChange) %>%
                    </span>
                </div>
                <p class="detail-label">Testimonials</p>
                <h2 class="detail-value">
                    <%= totalTestimonials %>
                </h2>
                <p class="detail-hint">Testimonials Growth vs last month</p>
            </div>

            <div class="stat-card detail events">
                <div class="detail-header">
                    <span class="detail-icon"><i class="fa-solid fa-calendar-check"></i></span>
                    <span class="trend-badge <%= eventsChange >= 0 ? 'up' : 'down' %>">
                        <i class="fa-solid <%= eventsChange >= 0 ? 'fa-arrow-trend-up' : 'fa-arrow-trend-down' %>"></i>
                        <%= Math.abs(eventsChange) %>%
                    </span>
                </div>
                <p class="detail-label">Events</p>
                <h2 class="detail-value">
                    <%= totalEvents %>
                </h2>
                <p class="detail-hint">Events Growth vs last month</p>
            </div>

            <div class="stat-card detail materials">
                <div class="detail-header">
                    <span class="detail-icon"><i class="fa-solid fa-file-pdf"></i></span>
                    <span class="trend-badge <%= materialsChange >= 0 ? 'up' : 'down' %>">
                        <i
                            class="fa-solid <%= materialsChange >= 0 ? 'fa-arrow-trend-up' : 'fa-arrow-trend-down' %>"></i>
                        <%= Math.abs(materialsChange) %>%
                    </span>
                </div>
                <p class="detail-label">Marketing Assets</p>
                <h2 class="detail-value">
                    <%= totalMaterials %>
                </h2>
                <p class="detail-hint">Marketing Assets Growth vs last month</p>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="grid grid-2" style="gap: 2rem; margin-top: 2rem;">
        <div class="card chart-card">
            <div class="chart-header">
                <h3>Products per Category</h3>
                <div class="chart-legend">
                    <span class="dot primary"></span> Count of Products
                </div>
            </div>
            <div style="height: 350px; position: relative; padding: 1rem;">
                <canvas id="categoryChart" data-chart='<%- JSON.stringify(categoriesData) %>'></canvas>
            </div>
        </div>

        <div class="card chart-card">
            <div class="chart-header">
                <h3>Top 10 Suppliers</h3>
                <div class="chart-legend">
                    <span class="dot secondary"></span> Count of Products
                </div>
            </div>
            <div style="height: 350px; position: relative; padding: 1rem;">
                <canvas id="supplierChart" data-chart='<%- JSON.stringify(suppliersData) %>'></canvas>
            </div>
        </div>
    </div>

    <div class="date-panel-backdrop" id="datePanelBackdrop"></div>
    <aside class="date-range-panel" id="dateRangePanel" aria-hidden="true">
        <form action="/admin" method="GET" id="dateRangeForm">
            <input type="hidden" name="preset" id="datePresetInput" value="<%= activePreset %>">
            <input type="hidden" name="startDate" id="startDateInput" value="<%= activeStartDate %>">
            <input type="hidden" name="endDate" id="endDateInput" value="<%= activeEndDate %>">

            <div class="date-panel-header">
                <button type="button" class="date-icon-button" id="closeDateRangePanel" aria-label="Close date range panel">
                    <i class="fa-solid fa-chevron-left"></i>
                </button>
                <h2>Date range</h2>
            </div>

            <div class="date-panel-body">
                <div class="date-presets" id="datePresetList">
                    <label><input type="radio" name="datePresetOption" value="today"> <span>Today</span></label>
                    <label><input type="radio" name="datePresetOption" value="yesterday"> <span>Yesterday</span></label>
                    <label><input type="radio" name="datePresetOption" value="last_7_days"> <span>Last 7 days</span></label>
                    <label><input type="radio" name="datePresetOption" value="last_14_days"> <span>Last 14 days</span></label>
                    <label><input type="radio" name="datePresetOption" value="last_28_days"> <span>Last 28 days</span></label>
                    <label><input type="radio" name="datePresetOption" value="last_30_days"> <span>Last 30 days</span></label>
                    <label><input type="radio" name="datePresetOption" value="this_week"> <span>This week</span></label>
                    <label><input type="radio" name="datePresetOption" value="last_week"> <span>Last week</span></label>
                    <label><input type="radio" name="datePresetOption" value="this_month"> <span>This month</span></label>
                    <label><input type="radio" name="datePresetOption" value="last_month"> <span>Last month</span></label>
                    <label><input type="radio" name="datePresetOption" value="all_time"> <span>All time</span></label>
                    <label><input type="radio" name="datePresetOption" value="custom"> <span>Custom</span></label>
                </div>

                <div class="date-picker-area">
                    <div class="date-actions">
                        <button type="button" class="date-secondary-button" id="clearDateRange">Clear</button>
                        <button type="button" class="date-secondary-button" id="todayDateRange">Today</button>
                        <button type="button" class="date-icon-button bordered" id="previousMonths" aria-label="Previous months">
                            <i class="fa-solid fa-chevron-left"></i>
                        </button>
                        <button type="button" class="date-icon-button bordered" id="nextMonths" aria-label="Next months">
                            <i class="fa-solid fa-chevron-right"></i>
                        </button>
                    </div>

                    <div class="calendar-grid" id="calendarGrid"></div>

                    <div class="date-input-row">
                        <label>
                            <span>Start date</span>
                            <div class="date-display-input active">
                                <input type="text" id="startDateDisplay" readonly>
                                <i class="fa-regular fa-calendar"></i>
                            </div>
                        </label>
                        <label>
                            <span>End date</span>
                            <div class="date-display-input">
                                <input type="text" id="endDateDisplay" readonly>
                                <i class="fa-regular fa-calendar"></i>
                            </div>
                        </label>
                    </div>
                    <p class="date-helper-text">Pick a start date, then an end date from the calendar.</p>
                </div>
            </div>

            <div class="date-panel-footer">
                <button type="button" class="date-cancel-button" id="cancelDateRange">Cancel</button>
                <button type="submit" class="date-filter-button">Filter</button>
            </div>
        </form>
    </aside>
</div>

<style>
    .dashboard-page {
        padding: 1rem 0;
    }

    .dashboard-topbar {
        margin-bottom: 2.5rem;
        position: relative;
        z-index: 1;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1.5rem;
    }

    .dashboard-topbar h1 {
        font-size: 2.2rem;
        color: var(--blue-darkest);
        margin: 0 0 0.5rem;
        font-weight: 800;
        letter-spacing: -1px;
    }

    .dashboard-topbar p {
        color: var(--gray-600);
        font-size: 1.1rem;
        margin: 0;
    }

    .dashboard-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .dashboard-pdf-button {
        min-height: 42px;
        border: 1px solid var(--gray-200);
        border-radius: 8px;
        background: var(--white);
        color: var(--blue-darkest);
        padding: 0 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        box-shadow: 0 8px 22px rgba(15, 23, 42, 0.06);
        white-space: nowrap;
        text-decoration: none;
    }

    .dashboard-pdf-button:hover {
        border-color: var(--blue-light);
        color: var(--blue-medium);
    }

    .date-range-button {
        min-height: 42px;
        border: 1px solid var(--gray-200);
        border-radius: 8px;
        background: var(--white);
        color: var(--blue-darkest);
        padding: 0 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        box-shadow: 0 8px 22px rgba(15, 23, 42, 0.06);
        white-space: nowrap;
    }

    .date-range-button:hover {
        border-color: var(--blue-light);
        color: var(--blue-medium);
    }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .stats-row.main-stats {
        grid-template-columns: repeat(4, 1fr);
    }

    .stat-card {
        background: white;
        border-radius: 8px;
        padding: 1.35rem;
        position: relative;
        overflow: hidden;
        border: 1px solid var(--gray-200);
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .stat-card:hover {
        border-color: var(--gray-300);
        box-shadow: 0 6px 14px rgba(15, 23, 42, 0.06);
    }

    .stat-card.glass {
        background: var(--white);
    }

    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.05rem;
        margin-bottom: 1.15rem;
    }

    .products .stat-icon {
        background: var(--blue-lightest);
        color: var(--blue-dark);
    }

    .companies .stat-icon {
        background: #e5f5ee;
        color: #047857;
    }

    .suppliers .stat-icon {
        background: #fff4df;
        color: #b45309;
    }

    .completeness .stat-icon {
        background: var(--gray-100);
        color: var(--blue-medium);
    }

    .stat-label {
        color: var(--gray-500);
        font-size: 0.78rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.4px;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--blue-darkest);
        margin: 0;
        line-height: 1.05;
        letter-spacing: 0;
    }

    .stat-footer {
        margin-top: 1.15rem;
        padding-top: 0.85rem;
        border-top: 1px solid var(--gray-100);
        font-size: 0.78rem;
        color: var(--gray-500);
        display: flex;
        align-items: center;
        gap: 0.45rem;
        font-weight: 400;
        line-height: 1.4;
    }

    .completeness-track {
        height: 6px;
        border-radius: var(--border-radius-full);
        background: var(--gray-100);
        overflow: hidden;
        margin-top: 1rem;
    }

    .completeness-fill {
        height: 100%;
        border-radius: inherit;
        background: var(--blue-medium);
    }

    .stat-card.detail {
        padding: 1.25rem;
        background: var(--white);
    }

    .detail-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.25rem;
    }

    .detail-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.95rem;
    }

    .testimonials .detail-icon {
        background: #fee2e2;
        color: #ef4444;
    }

    .events .detail-icon {
        background: #ede9fe;
        color: #8b5cf6;
    }

    .materials .detail-icon {
        background: #dbeafe;
        color: #3b82f6;
    }

    .active-products .detail-icon {
        background: #dcfce7;
        color: #15803d;
    }

    .inactive-products .detail-icon {
        background: var(--gray-100);
        color: var(--gray-600);
    }

    .missing-images .detail-icon {
        background: #fef3c7;
        color: #b45309;
    }

    .trend-badge {
        font-size: 0.72rem;
        font-weight: 600;
        padding: 4px 8px;
        border-radius: 999px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .trend-badge.up {
        background: #ecfdf5;
        color: #065f46;
        border: 1px solid #d1fae5;
    }

    .trend-badge.down {
        background: #fef2f2;
        color: #991b1b;
        border: 1px solid #fee2e2;
    }

    .detail-label {
        font-size: 0.78rem;
        color: var(--gray-500);
        font-weight: 600;
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 0.4px;
    }

    .detail-value {
        font-size: 1.85rem;
        font-weight: 700;
        color: var(--blue-darkest);
        margin: 0.25rem 0;
        letter-spacing: 0;
    }

    .detail-hint {
        font-size: 0.78rem;
        color: var(--gray-500);
        margin: 0;
        font-weight: 400;
    }

    .chart-card {
        padding: 0 !important;
        background: white;
        border-radius: 24px;
        border: 1px solid rgba(0, 0, 0, 0.05);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    }

    .chart-header {
        padding: 1.5rem 2rem;
        border-bottom: 1px solid rgba(0, 0, 0, 0.03);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .chart-header h3 {
        margin: 0;
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--blue-darkest);
    }

    .chart-legend {
        display: flex;
        align-items: center;
        gap: 15px;
        font-size: 0.8rem;
        color: var(--gray-500);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
    }

    .dot.primary {
        background: #0284c7;
    }

    .dot.secondary {
        background: #10b981;
    }

    .date-panel-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.28);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s ease;
        z-index: 1000;
    }

    .date-panel-backdrop.open {
        opacity: 1;
        pointer-events: auto;
    }

    .date-range-panel {
        position: fixed;
        top: 0;
        right: 0;
        width: min(780px, calc(100vw - 16px));
        height: 100vh;
        background: var(--white);
        box-shadow: -24px 0 60px rgba(15, 23, 42, 0.18);
        transform: translateX(105%);
        transition: transform 0.24s ease;
        z-index: 1001;
        display: flex;
    }

    .date-range-panel.open {
        transform: translateX(0);
    }

    .date-range-panel form {
        width: 100%;
        min-height: 0;
        display: flex;
        flex-direction: column;
    }

    .date-panel-header {
        height: 64px;
        padding: 0 1.25rem;
        border-bottom: 1px solid var(--gray-200);
        display: flex;
        align-items: center;
        gap: 1.25rem;
        flex: 0 0 auto;
    }

    .date-panel-header h2 {
        margin: 0;
        font-size: 1.1rem;
        color: var(--blue-darkest);
        font-weight: 600;
    }

    .date-panel-body {
        min-height: 0;
        flex: 1;
        display: grid;
        grid-template-columns: 210px 1fr;
        overflow: auto;
    }

    .date-presets {
        border-right: 1px solid var(--gray-200);
        padding: 0.85rem 1rem;
    }

    .date-presets label {
        min-height: 34px;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        color: var(--gray-700);
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
    }

    .date-presets input {
        width: 14px;
        height: 14px;
        margin: 0;
        accent-color: var(--blue-medium);
    }

    .date-picker-area {
        padding: 1rem 1rem 1.5rem;
    }

    .date-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 0.55rem;
        margin-bottom: 1rem;
    }

    .date-secondary-button,
    .date-cancel-button,
    .date-filter-button,
    .date-icon-button {
        height: 38px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.85rem;
        cursor: pointer;
    }

    .date-secondary-button,
    .date-cancel-button {
        border: 1px solid var(--gray-300);
        background: var(--white);
        color: var(--gray-700);
        padding: 0 0.9rem;
    }

    .date-secondary-button:hover,
    .date-cancel-button:hover,
    .date-icon-button.bordered:hover {
        border-color: var(--blue-light);
        background: var(--gray-50);
    }

    .date-filter-button {
        border: 1px solid var(--blue-medium);
        background: var(--blue-medium);
        color: var(--white);
        padding: 0 1.15rem;
    }

    .date-icon-button {
        width: 38px;
        border: 0;
        background: transparent;
        color: var(--gray-600);
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .date-icon-button.bordered {
        border: 1px solid var(--gray-300);
        background: var(--white);
        color: var(--blue-dark);
    }

    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
    }

    .calendar-month {
        border: 1px solid var(--gray-200);
        border-radius: 8px;
        padding: 0.85rem;
    }

    .calendar-title {
        text-align: center;
        color: var(--blue-darkest);
        font-weight: 600;
        font-size: 0.98rem;
        margin-bottom: 0.85rem;
    }

    .calendar-weekdays,
    .calendar-days {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 0.28rem;
    }

    .calendar-weekdays span {
        color: var(--gray-500);
        font-size: 0.74rem;
        font-weight: 600;
        text-align: center;
    }

    .calendar-day {
        aspect-ratio: 1;
        border: 1px solid transparent;
        border-radius: 6px;
        background: transparent;
        color: var(--gray-700);
        font-weight: 500;
        font-size: 0.85rem;
        cursor: pointer;
    }

    .calendar-day:hover {
        border-color: var(--blue-lightest);
        background: var(--gray-50);
    }

    .calendar-day.in-range {
        background: var(--blue-lightest);
        color: var(--blue-darkest);
    }

    .calendar-day.range-start,
    .calendar-day.range-end {
        background: var(--blue-medium);
        color: var(--white);
        border-color: var(--blue-medium);
    }

    .calendar-day.today:not(.range-start):not(.range-end) {
        border-color: var(--blue-light);
        color: var(--blue-medium);
    }

    .calendar-day.empty {
        pointer-events: none;
    }

    .date-input-row {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
        margin-top: 1rem;
    }

    .date-input-row label span {
        display: block;
        margin-bottom: 0.35rem;
        color: var(--gray-500);
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
    }

    .date-display-input {
        height: 46px;
        border: 1px solid var(--gray-300);
        border-radius: 8px;
        display: flex;
        align-items: center;
        padding: 0 0.85rem;
        gap: 0.6rem;
        background: var(--white);
    }

    .date-display-input.active {
        border-color: var(--blue-medium);
        box-shadow: 0 0 0 3px rgba(0, 91, 150, 0.12);
    }

    .date-display-input input {
        border: 0;
        outline: 0;
        min-width: 0;
        flex: 1;
        font-size: 0.92rem;
        color: var(--gray-800);
        background: transparent;
    }

    .date-display-input i {
        color: var(--gray-500);
    }

    .date-helper-text {
        margin: 0.85rem 0 0;
        color: var(--gray-500);
        font-size: 0.88rem;
    }

    .date-panel-footer {
        border-top: 1px solid var(--gray-200);
        padding: 0.85rem 1rem;
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        flex: 0 0 auto;
    }

    @media (max-width: 1024px) {
        .stats-row {
            grid-template-columns: repeat(2, 1fr);
        }

        .stats-row.main-stats {
            grid-template-columns: repeat(2, 1fr);
        }

        .date-panel-body {
            grid-template-columns: 190px 1fr;
        }

        .calendar-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 768px) {
        .dashboard-topbar {
            flex-direction: column;
            align-items: stretch;
        }

        .date-range-button {
            justify-content: center;
            width: 100%;
        }

        .dashboard-actions,
        .dashboard-pdf-button {
            width: 100%;
        }

        .dashboard-pdf-button {
            justify-content: center;
        }

        .stats-row {
            grid-template-columns: 1fr;
        }

        .stats-row.main-stats {
            grid-template-columns: 1fr;
        }

        .grid-2 {
            grid-template-columns: 1fr;
        }

        .date-range-panel {
            width: 100vw;
        }

        .date-panel-body {
            display: block;
        }

        .date-presets {
            border-right: 0;
            border-bottom: 1px solid var(--gray-200);
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .date-input-row {
            grid-template-columns: 1fr;
        }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const initialDateRange = {
            preset: '<%= activePreset %>',
            startDate: '<%= activeStartDate %>',
            endDate: '<%= activeEndDate %>'
        };

        const panel = document.getElementById('dateRangePanel');
        const backdrop = document.getElementById('datePanelBackdrop');
        const openPanelButton = document.getElementById('openDateRangePanel');
        const closePanelButton = document.getElementById('closeDateRangePanel');
        const cancelButton = document.getElementById('cancelDateRange');
        const dateRangeForm = document.getElementById('dateRangeForm');
        const presetInput = document.getElementById('datePresetInput');
        const startInput = document.getElementById('startDateInput');
        const endInput = document.getElementById('endDateInput');
        const startDisplay = document.getElementById('startDateDisplay');
        const endDisplay = document.getElementById('endDateDisplay');
        const calendarGrid = document.getElementById('calendarGrid');
        const buttonLabel = document.getElementById('dateRangeButtonLabel');
        const presetLabels = {
            today: 'Today',
            yesterday: 'Yesterday',
            last_7_days: 'Last 7 days',
            last_14_days: 'Last 14 days',
            last_28_days: 'Last 28 days',
            last_30_days: 'Last 30 days',
            this_week: 'This week',
            last_week: 'Last week',
            this_month: 'This month',
            last_month: 'Last month',
            all_time: 'All time',
            custom: 'Custom'
        };
        const monthFormatter = new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' });
        const displayFormatter = new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
        let selectedStart = parseLocalDate(initialDateRange.startDate) || startOfMonth(new Date());
        let selectedEnd = parseLocalDate(initialDateRange.endDate) || endOfMonth(new Date());
        let visibleMonth = startOfMonth(selectedStart);
        let selectingEnd = true;

        function parseLocalDate(value) {
            if (!value) return null;
            const parts = value.split('-').map(Number);
            if (parts.length !== 3 || parts.some(isNaN)) return null;
            return new Date(parts[0], parts[1] - 1, parts[2]);
        }

        function toLocalDateString(date) {
            return [
                date.getFullYear(),
                String(date.getMonth() + 1).padStart(2, '0'),
                String(date.getDate()).padStart(2, '0')
            ].join('-');
        }

        function startOfMonth(date) {
            return new Date(date.getFullYear(), date.getMonth(), 1);
        }

        function endOfMonth(date) {
            return new Date(date.getFullYear(), date.getMonth() + 1, 0);
        }

        function addDays(date, days) {
            const next = new Date(date);
            next.setDate(next.getDate() + days);
            return next;
        }

        function addMonths(date, months) {
            return new Date(date.getFullYear(), date.getMonth() + months, 1);
        }

        function startOfWeek(date) {
            const day = date.getDay() || 7;
            return addDays(date, 1 - day);
        }

        function sameDate(a, b) {
            return a && b && toLocalDateString(a) === toLocalDateString(b);
        }

        function setAllTimeRange() {
            presetInput.value = 'all_time';
            startInput.value = '';
            endInput.value = '';
            startDisplay.value = 'All time';
            endDisplay.value = 'All time';
            buttonLabel.textContent = presetLabels.all_time;
            selectingEnd = true;

            document.querySelectorAll('input[name="datePresetOption"]').forEach((radio) => {
                radio.checked = radio.value === 'all_time';
            });

            renderCalendars();
        }

        function setRange(start, end, preset) {
            selectedStart = start <= end ? start : end;
            selectedEnd = start <= end ? end : start;
            presetInput.value = preset;
            startInput.value = toLocalDateString(selectedStart);
            endInput.value = toLocalDateString(selectedEnd);
            startDisplay.value = displayFormatter.format(selectedStart);
            endDisplay.value = displayFormatter.format(selectedEnd);
            selectingEnd = true;

            document.querySelectorAll('input[name="datePresetOption"]').forEach((radio) => {
                radio.checked = radio.value === preset;
            });

            buttonLabel.textContent = preset === 'custom'
                ? `${displayFormatter.format(selectedStart)} - ${displayFormatter.format(selectedEnd)}`
                : presetLabels[preset] || 'Date range';

            if (selectedStart < visibleMonth || selectedStart > endOfMonth(addMonths(visibleMonth, 1))) {
                visibleMonth = startOfMonth(selectedStart);
            }

            renderCalendars();
        }

        function applyPreset(preset) {
            if (preset === 'all_time') {
                setAllTimeRange();
                return;
            }

            const today = new Date();
            let start = today;
            let end = today;

            if (preset === 'yesterday') {
                start = addDays(today, -1);
                end = addDays(today, -1);
            } else if (preset === 'last_7_days') {
                start = addDays(today, -6);
            } else if (preset === 'last_14_days') {
                start = addDays(today, -13);
            } else if (preset === 'last_28_days') {
                start = addDays(today, -27);
            } else if (preset === 'last_30_days') {
                start = addDays(today, -29);
            } else if (preset === 'this_week') {
                start = startOfWeek(today);
                end = addDays(start, 6);
            } else if (preset === 'last_week') {
                end = addDays(startOfWeek(today), -1);
                start = addDays(end, -6);
            } else if (preset === 'this_month') {
                start = startOfMonth(today);
                end = endOfMonth(today);
            } else if (preset === 'last_month') {
                const lastMonth = addMonths(today, -1);
                start = startOfMonth(lastMonth);
                end = endOfMonth(lastMonth);
            }

            setRange(start, end, preset);
        }

        function renderCalendars() {
            calendarGrid.innerHTML = '';
            [visibleMonth, addMonths(visibleMonth, 1)].forEach((monthDate) => {
                const month = document.createElement('section');
                month.className = 'calendar-month';

                const title = document.createElement('div');
                title.className = 'calendar-title';
                title.textContent = monthFormatter.format(monthDate);
                month.appendChild(title);

                const weekdays = document.createElement('div');
                weekdays.className = 'calendar-weekdays';
                ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'].forEach((day) => {
                    const el = document.createElement('span');
                    el.textContent = day;
                    weekdays.appendChild(el);
                });
                month.appendChild(weekdays);

                const days = document.createElement('div');
                days.className = 'calendar-days';
                const firstDay = new Date(monthDate.getFullYear(), monthDate.getMonth(), 1);
                const leadingDays = (firstDay.getDay() + 6) % 7;
                const dayCount = endOfMonth(monthDate).getDate();

                for (let i = 0; i < leadingDays; i++) {
                    const empty = document.createElement('span');
                    empty.className = 'calendar-day empty';
                    days.appendChild(empty);
                }

                for (let day = 1; day <= dayCount; day++) {
                    const date = new Date(monthDate.getFullYear(), monthDate.getMonth(), day);
                    const button = document.createElement('button');
                    button.type = 'button';
                    button.className = 'calendar-day';
                    button.textContent = day;
                    button.dataset.date = toLocalDateString(date);

                    if (presetInput.value !== 'all_time' && date > selectedStart && date < selectedEnd) button.classList.add('in-range');
                    if (presetInput.value !== 'all_time' && sameDate(date, selectedStart)) button.classList.add('range-start');
                    if (presetInput.value !== 'all_time' && sameDate(date, selectedEnd)) button.classList.add('range-end');
                    if (sameDate(date, new Date())) button.classList.add('today');

                    button.addEventListener('click', () => {
                        const clicked = parseLocalDate(button.dataset.date);
                        if (!selectingEnd || clicked < selectedStart) {
                            setRange(clicked, clicked, 'custom');
                            selectingEnd = true;
                        } else {
                            setRange(selectedStart, clicked, 'custom');
                            selectingEnd = false;
                        }
                    });

                    days.appendChild(button);
                }

                month.appendChild(days);
                calendarGrid.appendChild(month);
            });
        }

        function openPanel() {
            panel.classList.add('open');
            backdrop.classList.add('open');
            panel.setAttribute('aria-hidden', 'false');
        }

        function closePanel() {
            panel.classList.remove('open');
            backdrop.classList.remove('open');
            panel.setAttribute('aria-hidden', 'true');
        }

        document.querySelectorAll('input[name="datePresetOption"]').forEach((radio) => {
            radio.addEventListener('change', () => applyPreset(radio.value));
        });

        document.getElementById('previousMonths').addEventListener('click', () => {
            visibleMonth = addMonths(visibleMonth, -2);
            renderCalendars();
        });

        document.getElementById('nextMonths').addEventListener('click', () => {
            visibleMonth = addMonths(visibleMonth, 2);
            renderCalendars();
        });

        document.getElementById('todayDateRange').addEventListener('click', () => applyPreset('today'));
        document.getElementById('clearDateRange').addEventListener('click', () => applyPreset('this_month'));
        dateRangeForm.addEventListener('submit', () => {
            document.querySelectorAll('input[name="datePresetOption"]').forEach((radio) => {
                radio.disabled = true;
            });
        });
        openPanelButton.addEventListener('click', openPanel);
        closePanelButton.addEventListener('click', closePanel);
        cancelButton.addEventListener('click', closePanel);
        backdrop.addEventListener('click', closePanel);
        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') closePanel();
        });

        if (initialDateRange.preset === 'all_time') {
            setAllTimeRange();
        } else {
            setRange(selectedStart, selectedEnd, initialDateRange.preset || 'this_month');
        }

        // Global Chart Defaults
        Chart.defaults.font.family = "'Inter', sans-serif";
        Chart.defaults.color = '#64748b';
        Chart.defaults.scale.grid.color = 'rgba(0,0,0,0.05)';

        // Function to safely parse data from canvas attribute
        const getChartData = (id) => {
            const el = document.getElementById(id);
            try {
                return JSON.parse(el.getAttribute('data-chart'));
            } catch (e) {
                console.error('Failed to parse chart data for ' + id, e);
                return [];
            }
        };

        // Products per Category Chart
        const catCtx = document.getElementById('categoryChart').getContext('2d');
        const catDataRaw = getChartData('categoryChart');

        new Chart(catCtx, {
            type: 'bar',
            data: {
                labels: catDataRaw.map(d => d.name),
                datasets: [{
                    label: 'Products',
                    data: catDataRaw.map(d => d.count),
                    backgroundColor: 'rgba(2, 132, 199, 0.8)',
                    hoverBackgroundColor: '#0284c7',
                    borderRadius: 10,
                    maxBarThickness: 35
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: '#1e293b',
                        padding: 12,
                        titleFont: { size: 14, weight: 'bold' },
                        bodyFont: { size: 13 },
                        cornerRadius: 10,
                        displayColors: false,
                        boxPadding: 5
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { font: { weight: '600' } },
                        border: { display: true, color: 'rgba(0,0,0,0.15)', width: 2 }
                    },
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1, padding: 10 },
                        border: { display: true, color: 'rgba(0,0,0,0.15)', width: 2 },
                        grid: { color: 'rgba(0,0,0,0.05)' }
                    }
                }
            }
        });

        // Top Suppliers Chart (Horizontal)
        const supCtx = document.getElementById('supplierChart').getContext('2d');
        const supDataRaw = getChartData('supplierChart');

        new Chart(supCtx, {
            type: 'bar',
            data: {
                labels: supDataRaw.map(d => d.name),
                datasets: [{
                    label: 'Products',
                    data: supDataRaw.map(d => d.product_count),
                    backgroundColor: 'rgba(16, 185, 129, 0.8)',
                    hoverBackgroundColor: '#10b981',
                    borderRadius: 10,
                    maxBarThickness: 30
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                indexAxis: 'y',
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: '#1e293b',
                        padding: 12,
                        titleFont: { size: 14, weight: 'bold' },
                        bodyFont: { size: 13 },
                        cornerRadius: 10,
                        displayColors: false,
                        boxPadding: 5
                    }
                },
                scales: {
                    x: {
                        beginAtZero: true,
                        ticks: { stepSize: 2, padding: 10 },
                        grid: { display: true, color: 'rgba(0,0,0,0.05)' },
                        border: { display: true, color: 'rgba(0,0,0,0.15)', width: 2 }
                    },
                    y: {
                        grid: { display: false },
                        border: { display: true, color: 'rgba(0,0,0,0.15)', width: 2 },
                        ticks: { font: { weight: '600' } }
                    }
                }
            }
        });
    });
</script>
